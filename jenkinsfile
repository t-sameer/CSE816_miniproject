pipeline {
    agent any
    environment {
        DOCKER_HUB_CREDENTIALS_ID = 'dockerhub-creds'
        DOCKER_IMAGE = 'tsameer/calculator:latest'
        NOTIFICATION_EMAIL = 'employee.esdproject@gmail.com'
    }
    stages {
        stage('Checkout Code') {

            steps {
                    echo 'Pulling code from GitHub...'
                    checkout scm
                    }
        }
        stage('Build & Test with Maven') {

            steps {
                    echo 'Compiling and running JUnit tests...'
                    sh 'mvn clean package'
                    }
        }
        stage('Build Docker Image') {

            steps {
                    echo 'Building the Docker Image...'
                    sh "docker build -t ${DOCKER_IMAGE} ."
                    }
        }
        stage('Push to Docker Hub') {

            steps {
                echo 'Pushing image to Docker Hub...'
                withCredentials([usernamePassword(credentialsId: env.DOCKER_HUB_CREDENTIALS_ID, passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                    sh "echo $DOCKER_PASSWORD | docker login -u $DOCKER_USERNAME --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}"
                }
            }
        }
    }
    post {
        always {

            sh "docker rmi ${DOCKER_IMAGE} || true"
        }
        success {
            echo 'Build and Push Successful! Sending email...'
            mail to: "${NOTIFICATION_EMAIL}",
                 subject: "SUCCESS: Jenkins Pipeline ${currentBuild.fullDisplayName}",
                 body: "Calculator pipeline completed successfully.\n\nCheck console output at: ${env.BUILD_URL}"
        }
        failure {
            echo 'Pipeline failed. Sending email...'
            mail to: "${NOTIFICATION_EMAIL}",
                 subject: "FAILED: Jenkins Pipeline ${currentBuild.fullDisplayName}",
                 body: "Calculator pipeline failed.\n\nCheck console output at: ${env.BUILD_URL}"
        }
    }
}